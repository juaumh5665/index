{
  "rewrites": [
    { "source": "/app", "destination": "/app.html" },
    { "source": "/app/", "destination": "/app.html" },
    { "source": "/tv", "destination": "/tv.html" },
    { "source": "/tv/", "destination": "/tv.html" },
    { "source": "/tv/:slug", "destination": "/tv.html" },
    { "source": "/tv-legacy", "destination": "/tv-legacy.html" },
    { "source": "/tv-legacy/", "destination": "/tv-legacy.html" },
    { "source": "/tv-legacy/:slug", "destination": "/tv-legacy.html" },
    { "source": "/torneio", "destination": "/torneio.html" },
    { "source": "/torneio/", "destination": "/torneio.html" },
    { "source": "/torneio/:slug", "destination": "/torneio.html" },
    { "source": "/r/:slug", "destination": "/ranking.html" },
    { "source": "/termos", "destination": "/termos.html" },
    { "source": "/termos/", "destination": "/termos.html" },
    { "source": "/privacidade", "destination": "/privacidade.html" },
    { "source": "/privacidade/", "destination": "/privacidade.html" }
  ],
  "redirects": [
    { "source": "/stackos.html", "destination": "/app", "statusCode": 301 }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/tv",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/torneio",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" }
      ]
    },
    {
      "source": "/app",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" }
      ]
    },
    {
      "source": "/ranking.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300" }
      ]
    }
  ]
}
